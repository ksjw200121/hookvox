generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                      String                 @id @default(cuid())
  email                   String                 @unique
  name                    String?
  avatarUrl               String?
  supabaseId              String                 @unique
  instagramHandle         String?
  accountStatus           AccountStatus          @default(ACTIVE)
  internalNoteSummary     String?
  createdAt               DateTime               @default(now())
  updatedAt               DateTime               @updatedAt
  role                    String                 @default("USER")
  contents                Content[]
  scripts                 Script[]
  subscription            Subscription?
  usageLogs               UsageLog[]             @relation("UsageLogPublicUser")
  viralEntries            ViralDatabase[]        @relation("ViralDatabasePublicUser")
  orders                  Order[]
  adminNotesReceived      AdminNote[]            @relation("AdminNoteTargetUser")
  adminNotesAuthored      AdminNote[]            @relation("AdminNoteAuthorUser")
  adminAuditLogsTarget    AdminAuditLog[]        @relation("AdminAuditTargetUser")
  adminAuditLogsActor     AdminAuditLog[]        @relation("AdminAuditActorUser")
  quotaAdjustmentsTarget  ManualQuotaAdjustment[] @relation("QuotaAdjustmentTargetUser")
  quotaAdjustmentsActor   ManualQuotaAdjustment[] @relation("QuotaAdjustmentActorUser")

  @@map("users")
}

model Subscription {
  id                    String    @id @default(cuid())
  userId                String    @unique
  plan                  Plan      @default(FREE)
  status                SubStatus @default(ACTIVE)
  tapPaySubId           String?
  ecpayTradeNo          String?
  ecpayMerchantTradeNo  String?
  startDate             DateTime  @default(now())
  endDate               DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("subscriptions")
}

model Content {
  id        String           @id @default(cuid())
  userId    String
  url       String
  platform  Platform
  caption   String?
  likes     Int?
  comments  Int?
  views     Int?
  rawData   Json?
  createdAt DateTime         @default(now())
  analysis  ContentAnalysis?
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  scripts   Script[]

  @@map("contents")
}

model ContentAnalysis {
  id                 String   @id @default(cuid())
  contentId          String   @unique
  targetAudience     String?
  viralReasons       Json?
  hookType           String?
  emotionType        String?
  structureBreakdown Json?
  painPoints         Json?
  ctaType            String?
  category           String?
  hookStrength       Float?
  topicRelevance     Float?
  clarityScore       Float?
  emotionalPull      Float?
  ctaStrength        Float?
  viralScore         Float?
  createdAt          DateTime @default(now())
  content            Content  @relation(fields: [contentId], references: [id], onDelete: Cascade)

  @@map("content_analyses")
}

model Script {
  id           String      @id @default(cuid())
  userId       String
  contentId    String?
  topic        String
  style        ScriptStyle
  hook         String?
  body         String?
  caption      String?
  cta          String?
  shootingTips String?
  createdAt    DateTime    @default(now())
  content      Content?    @relation(fields: [contentId], references: [id])
  user         User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("scripts")
}

model UsageLog {
  id           String   @id @default(cuid())
  userId       String
  publicUserId String?
  action       UsageAction
  date         DateTime @default(now())
  createdAt    DateTime @default(now())
  publicUser   User?    @relation("UsageLogPublicUser", fields: [publicUserId], references: [id], onDelete: SetNull)

  @@map("usage_logs")
}

model ViralDatabase {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId       String
  publicUserId String?
  videoUrl     String?
  transcript   String?
  analysis     Json?
  createdAt    DateTime? @default(now()) @db.Timestamptz(6)
  isSaved      Boolean   @default(false)
  savedAt      DateTime? @db.Timestamptz(6)
  publicUser   User?     @relation("ViralDatabasePublicUser", fields: [publicUserId], references: [id], onDelete: SetNull)

  @@map("viral_database")
}

model IpUsage {
  id        String   @id @default(cuid())
  ip        String
  createdAt DateTime @default(now())

  @@index([ip, createdAt])
}

model request_guards {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  key          String   @unique
  user_id      String?
  ip           String?
  route        String
  window_start DateTime @db.Timestamptz(6)
  count        Int      @default(1)
  created_at   DateTime @default(now()) @db.Timestamptz(6)
  updated_at   DateTime @default(now()) @db.Timestamptz(6)

  @@index([ip])
  @@index([route])
  @@index([user_id])
}

model system_runtime_metrics {
  id                 String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  metric_date        DateTime @unique @db.Date
  analyze_count      Int      @default(0)
  generate_count     Int      @default(0)
  estimated_cost_usd Decimal  @default(0) @db.Decimal(12, 4)
  hard_locked        Boolean  @default(false)
  created_at         DateTime @default(now()) @db.Timestamptz(6)
  updated_at         DateTime @default(now()) @db.Timestamptz(6)

  @@index([metric_date])
}

model Order {
  id              String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId          String
  plan            String
  billingCycle    String
  amount          Decimal?       @db.Decimal(12, 2)
  merchantTradeNo String?        @unique @map("merchantTradeNo")
  tradeNo         String?        @map("tradeNo")
  status          String
  paidAt          DateTime?      @map("paidAt")
  createdAt       DateTime       @default(now()) @map("createdAt")
  updatedAt       DateTime       @default(now()) @map("updatedAt")
  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@map("orders")
}

model PaymentWebhookEvent {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  provider       String
  ok             Boolean
  stage          String
  message        String?
  checkMacValid  Boolean?  @map("check_mac_valid")
  merchantTradeNo String?  @map("merchant_trade_no")
  tradeNo        String?   @map("trade_no")
  rtnCode        String?   @map("rtn_code")
  tradeAmt       Decimal?  @map("trade_amt") @db.Decimal(12, 2)
  ip             String?
  userAgent      String?   @map("user_agent")
  raw            Json?
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([merchantTradeNo])
  @@index([tradeNo])
  @@map("payment_webhook_events")
}

model AdminNote {
  id           String   @id @default(cuid())
  userId       String
  authorUserId String
  note         String
  noteType     String   @default("GENERAL")
  isPinned     Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation("AdminNoteTargetUser", fields: [userId], references: [id], onDelete: Cascade)
  authorUser   User     @relation("AdminNoteAuthorUser", fields: [authorUserId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("admin_notes")
}

model AdminAuditLog {
  id          String   @id @default(cuid())
  actorUserId String?
  targetUserId String?
  entityType  String
  entityId    String?
  action      String
  reason      String?
  beforeJson  Json?
  afterJson   Json?
  metaJson    Json?
  createdAt   DateTime @default(now())
  actorUser   User?    @relation("AdminAuditActorUser", fields: [actorUserId], references: [id], onDelete: SetNull)
  targetUser  User?    @relation("AdminAuditTargetUser", fields: [targetUserId], references: [id], onDelete: SetNull)

  @@index([targetUserId, createdAt])
  @@index([actorUserId, createdAt])
  @@map("admin_audit_logs")
}

model ManualQuotaAdjustment {
  id           String       @id @default(cuid())
  userId       String
  actorUserId  String
  feature      QuotaFeature
  delta        Int
  reason       String
  effectiveFrom DateTime    @default(now())
  effectiveTo  DateTime?
  revokedAt    DateTime?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  user         User         @relation("QuotaAdjustmentTargetUser", fields: [userId], references: [id], onDelete: Cascade)
  actorUser    User         @relation("QuotaAdjustmentActorUser", fields: [actorUserId], references: [id], onDelete: Cascade)

  @@index([userId, feature])
  @@index([effectiveFrom, effectiveTo])
  @@map("manual_quota_adjustments")
}

enum Platform {
  INSTAGRAM
  TIKTOK
  YOUTUBE_SHORTS
}

enum Plan {
  FREE
  CREATOR
  PRO
  FLAGSHIP
}

enum AccountStatus {
  ACTIVE
  SUSPENDED
}

enum SubStatus {
  ACTIVE
  CANCELLED
  EXPIRED
}

enum ScriptStyle {
  EDUCATIONAL
  CONTROVERSIAL
  FEAR
  STORY
  CASUAL
  EXPERT
}

enum UsageAction {
  ANALYZE
  GENERATE_SCRIPT
  GENERATE_TITLES
  GENERATE_IDEAS
}

enum QuotaFeature {
  ANALYZE
  GENERATE
}

model SystemSettings {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  category  String   @default("GENERAL")
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([isRead, createdAt])
  @@map("contact_messages")
}