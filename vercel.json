{
  "framework": "nextjs",
  "functions": {
    "src/app/api/analyze/**": {
      "maxDuration": 300,
      "memory": 1024
    },
    "src/app/api/transcribe/**": {
      "maxDuration": 300,
      "memory": 1024
    },
    "src/app/api/generate/**": {
      "maxDuration": 120,
      "memory": 1024
    }
  },
  "crons": [
    {
      "path": "/api/cron/expire-subscriptions",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/cron/expiry-reminder",
      "schedule": "0 9 * * *"
    }
  ]
}
